# Bitterbot Podman environment
# Copy to bitterbot.podman.env.local and set BITTERBOT_GATEWAY_TOKEN (or use -e when running).
# This file can be used with:
#   BITTERBOT_PODMAN_ENV=/path/to/bitterbot.podman.env ./scripts/run-bitterbot-podman.sh launch

# Required: gateway auth token. Generate with: openssl rand -hex 32
# Set this before running the container (or use run-bitterbot-podman.sh which can generate it).
BITTERBOT_GATEWAY_TOKEN=

# Host port mapping (defaults; override if needed)
BITTERBOT_PODMAN_GATEWAY_HOST_PORT=19001
BITTERBOT_PODMAN_P2P_HOST_PORT=9100
BITTERBOT_PODMAN_DASHBOARD_HOST_PORT=9847

# Gateway bind (used by the launch script)
BITTERBOT_GATEWAY_BIND=lan

# Optional: LLM provider API keys (for zero cost use Ollama locally or Groq free tier)
# OLLAMA_API_KEY=ollama-local
# GROQ_API_KEY=
