# Bitterbot .env example
#
# Quick start:
# 1) Copy this file to `.env` (for local runs from this repo), OR to `~/.bitterbot/.env` (for launchd/systemd daemons).
# 2) Fill only the values you use.
# 3) Keep real secrets out of git.
#
# Env-source precedence for environment variables (highest -> lowest):
# process env, ./.env, ~/.bitterbot/.env, then bitterbot.json `env` block.
# Existing non-empty process env vars are not overridden by dotenv/config env loading.
# Note: direct config keys (for example `gateway.auth.token` or channel tokens in bitterbot.json)
# are resolved separately from env loading and often take precedence over env fallbacks.

# -----------------------------------------------------------------------------
# Gateway auth + paths
# -----------------------------------------------------------------------------
# Recommended if the gateway binds beyond loopback.
BITTERBOT_GATEWAY_TOKEN=change-me-to-a-long-random-token
# Example generator: openssl rand -hex 32

# Optional alternative auth mode (use token OR password).
# BITTERBOT_GATEWAY_PASSWORD=change-me-to-a-strong-password

# Optional path overrides (defaults shown for reference).
# BITTERBOT_STATE_DIR=~/.bitterbot
# BITTERBOT_CONFIG_PATH=~/.bitterbot/bitterbot.json
# BITTERBOT_HOME=~

# Optional: import missing keys from your login shell profile.
# BITTERBOT_LOAD_SHELL_ENV=1
# BITTERBOT_SHELL_ENV_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# Model provider API keys (set at least one)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...

# Optional additional providers
# ZAI_API_KEY=...
# AI_GATEWAY_API_KEY=...
# MINIMAX_API_KEY=...
# SYNTHETIC_API_KEY=...

# -----------------------------------------------------------------------------
# Channels (only set what you enable)
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Optional channel env fallbacks
# MATTERMOST_BOT_TOKEN=...
# MATTERMOST_URL=https://chat.example.com
# ZALO_BOT_TOKEN=...
# BITTERBOT_TWITCH_ACCESS_TOKEN=oauth:...

# -----------------------------------------------------------------------------
# Tools + voice/media (optional)
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...
# FIRECRAWL_API_KEY=...

# ELEVENLABS_API_KEY=...
# XI_API_KEY=...  # alias for ElevenLabs
# DEEPGRAM_API_KEY=...

# -----------------------------------------------------------------------------
# Agent wallet — Coinbase Developer Platform (CDP) credentials
# -----------------------------------------------------------------------------
# Required if the wallet is enabled. The onboarding wizard (`bitterbot
# configure --section wallet`) can collect these for you and persist them to
# the right places — it opens the CDP portal and walks through both steps.
#
# Portal: https://portal.cdp.coinbase.com
#
# 1) API Key (Project → API Keys → Create API key). Gives us the ID (UUID)
#    and Secret (Ed25519 base64). Note: CDP only shows the Secret once.
# CDP_API_KEY_ID=00000000-0000-0000-0000-000000000000
# CDP_API_KEY_SECRET=base64-ed25519-secret
#
# 2) Wallet Secret (Wallets → Wallet Secret → Create). Separate key that
#    authorizes signing on the agent's smart wallet. Also shown only once.
# CDP_WALLET_SECRET=long-base64-secret
#
# Base RPC endpoint. Defaults to the public Base node; swap in a paid RPC
# (Alchemy / QuickNode / Coinbase Cloud) if you're getting rate-limited.
# RPC_URL=https://mainnet.base.org

# -----------------------------------------------------------------------------
# Wallet funding — Stripe Crypto Onramp
# -----------------------------------------------------------------------------
# Tier 2: BYO Stripe keys (creates onramp sessions locally, bypasses hosted service)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
#
# Tier 3: BYO onramp endpoint (points to your own hosted onramp service)
# BITTERBOT_ONRAMP_URL=https://your-onramp.example.com
#
# Tier 1 (default): No keys or URL set → uses https://onramp.bitterbot.ai
