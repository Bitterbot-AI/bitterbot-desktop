{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Bitterbot",
  "version": "0.1.0",
  "identifier": "ai.bitterbot.desktop",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist-renderer"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Bitterbot",
        "width": 1280,
        "height": 860,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "resources": []
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
