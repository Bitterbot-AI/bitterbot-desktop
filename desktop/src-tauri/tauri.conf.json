{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Bitterbot",
  "version": "0.1.0",
  "identifier": "ai.bitterbot.desktop",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist-renderer"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Bitterbot",
        "width": 1280,
        "height": 860,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/bitterbot-gateway"],
    "resources": ["resources/*"],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Bitterbot-AI/bitterbot-desktop/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "REPLACE_WITH_OUTPUT_OF_TAURI_SIGNER_GENERATE"
    }
  }
}
