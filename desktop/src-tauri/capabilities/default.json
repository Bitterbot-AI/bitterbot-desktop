{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default Bitterbot desktop capability set",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "shell:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/bitterbot-gateway",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "updater:default",
    "process:default",
    "process:allow-restart"
  ]
}
