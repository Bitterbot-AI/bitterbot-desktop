# =============================================================================
# Bitterbot Control UI — Environment Variables
#
# This file is RECOMMENDED but OPTIONAL. If you run `pnpm bitterbot onboard`,
# the wizard will auto-generate `desktop/.env` for you with the right
# gateway token and URL pre-filled. Copy this file manually only if you are
# skipping the wizard or developing the Control UI against a custom gateway.
# =============================================================================

# Gateway WebSocket URL. Defaults to ws://127.0.0.1:19001 in the wizard output.
VITE_GATEWAY_URL=ws://127.0.0.1:19001

# Gateway auth token. Find it at ~/.bitterbot/bitterbot.json → gateway.auth.token
# after running `pnpm bitterbot onboard`. If your gateway uses password auth or
# is unauthenticated (not recommended), leave this blank.
VITE_GATEWAY_TOKEN=paste-your-gateway-token-here

# Optional: a friendly client name that identifies this browser session in
# gateway logs. Useful when multiple Control UI instances share one gateway.
VITE_GATEWAY_CLIENT_NAME=bitterbot-control-ui
