# =============================================================================
# BitterBot Desktop Agent — Environment Variables
# Copy to ~/.bitterbot/.env and fill in your keys.
# =============================================================================

# === Model Providers ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# === Web Search (powers web_search tool) ===
TAVILY_API_KEY=

# === Web Scraping (enhances web_fetch tool) ===
FIRECRAWL_API_KEY=

# === Gateway Auth (for Control UI dev server) ===
VITE_GATEWAY_URL=ws://127.0.0.1:19001
# Copy your gateway token from ~/.bitterbot/bitterbot.json → gateway.auth.token
# (generated during `bitterbot onboard`)
VITE_GATEWAY_TOKEN=paste-your-gateway-token-here
VITE_GATEWAY_CLIENT_NAME=bitterbot-desktop
